{
  "manifest_version": 3,
  "name": "Jukebox Lite",
  "version": "1.0",
  "description": "Jukebox music player but simpler and smoother.",
  "permissions": ["storage", "unlimitedStorage", "offscreen"],
 "action": {
    "default_popup": "src/popup/popup.html", 
    "default_title": "Open Player"
  },
  "background": {
    "service_worker": "src/background/background.js" 
  },
  "options_ui": {
    "page": "src/options/options.html", 
    "open_in_tab": true
  },
  "icons": {
    "128": "assets/icon_2.png" 
  }
}